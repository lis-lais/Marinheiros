{
  "name": "marinheiros-platform",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "start:sailor": "npm --workspace @marinheiros/sailor-service run start:dev",
    "start:schedule": "npm --workspace @marinheiros/schedule-service run start:dev",
    "start:gateway": "npm --workspace @marinheiros/api-gateway run start:dev",
    "start:all": "concurrently \"npm run start:sailor\" \"npm run start:schedule\" \"npm run start:gateway\"",
    "test": "jest --config jest.config.js"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@types/amqplib": "^0.10.8",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.0.0",
    "concurrently": "^8.2.0",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "typescript": "^5.5.4"
  },
  "dependencies": {
    "@nestjs/core": "^11.1.27",
    "@nestjs/mongoose": "^11.0.4",
    "@nestjs/platform-express": "^11.1.27",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.77.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.219.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-node": "^0.219.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "multer": "^2.2.0"
  }
}
